{
  "rules": {
    "reports": {
      ".read": "auth != null",
      ".write": false,
      "$reportId": {
        ".write": false
      }
    },
    "confirmations": {
      ".read": "auth != null",
      ".write": false
    },
    "comments": {
      ".read": "auth != null",
      ".write": false
    },
    "analytics": {
      ".read": "auth != null && (auth.token.role === 'moderator' || auth.token.role === 'official')",
      ".write": false
    }
  }
}
