{
  "rules": {
    "reports": {
      ".read": "auth != null",
      ".write": false,
      "$reportId": {
        ".write": false,
        ".indexOn": ["userId", "geohash", "status"]
      }
    },
    "confirmations": {
      ".read": "auth != null",
      ".write": false,
      ".indexOn": ["reportId"]
    },
    "comments": {
      ".read": "auth != null",
      ".write": false,
      ".indexOn": ["reportId"]
    },
    "analytics": {
      ".read": "auth != null && (auth.token.role === 'moderator' || auth.token.role === 'official')",
      ".write": false
    }
  }
}
