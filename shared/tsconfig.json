{
  "compilerOptions": {
    "target": "ES2017",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "noUnusedLocals": true
  },
  "include": ["*.ts"],
  "exclude": ["dist", "node_modules"]
}
