# Google Maps API key
# La misma key funciona para todos los servicios habilitados:
#  - Geocoding API
#  - Maps JavaScript API
#  - Maps SDK for Android
#  - Places API
#  - Places API (New)
#  - Routes API
#  - Street View Static API
GOOGLE_MAPS_API=

# Gemini AI key (opcional — si no se configura, usa GOOGLE_MAPS_API como fallback)
GEMINI_API_KEY=
